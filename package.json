{
  "name": "jaannz-spicy-spoon",
  "version": "1.0.0",
  "description": "Jaannz Spicy Spoon – Malaysian & Indian Restaurant – Angular 18 + Firebase + AWS S3/CloudFront",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port 4200 --open",
    "build": "ng build --configuration production",
    "build:dev": "ng build --configuration development",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "deploy": "node scripts/deploy.js",
    "deploy:rules": "firebase deploy --only firestore:rules,firestore:indexes"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "18.2.14",
    "@angular/common": "18.2.14",
    "@angular/compiler": "18.2.14",
    "@angular/core": "18.2.14",
    "@angular/fire": "^18.0.1",
    "@angular/forms": "18.2.14",
    "@angular/platform-browser": "18.2.14",
    "@angular/platform-browser-dynamic": "18.2.14",
    "@angular/router": "18.2.14",
    "firebase": "^10.14.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.6.0",
    "zone.js": "~0.14.10"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "18.2.19",
    "@angular/cli": "18.2.19",
    "@angular/compiler-cli": "18.2.14",
    "@aws-sdk/client-cloudfront": "^3.600.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "mime-types": "^2.1.35",
    "typescript": "~5.5.0"
  }
}
